      "seed": 1272318421,
      "version": 333,
      "versionNonce": 1259018196,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783507692100,
      "link": null,
      "locked": false,
      "text": "STORES (ร้านค้า): เชื่อมโยงกับ Users ที่เป็นผู้ขาย (Merchant) 1 ผู้ใช้สามารถมีได้ 1 ร้านค้า",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "STORES (ร้านค้า): เชื่อมโยงกับ Users ที่เป็นผู้ขาย (Merchant) 1 ผู้ใช้สามารถมีได้ 1 ร้านค้า",
      "autoResize": true,
