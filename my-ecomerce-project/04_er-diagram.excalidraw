      "link": null,
      "locked": false,
      "text": "ORDERS & ORDER_ITEMS (คำสั่งซื้อ): เก็บข้อมูลการสั่งซื้อ โดยมีฟิลด์ points_earned และ\npoints_used เพื่อผูกกับระบบ Loyalty",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ORDERS & ORDER_ITEMS (คำสั่งซื้อ): เก็บข้อมูลการสั่งซื้อ โดยมีฟิลด์ points_earned และ points_used เพื่อผูกกับระบบ Loyalty",
      "autoResize": false,
      "lineHeight": 1.25
    },
