      "seed": 1701072219,
      "version": 516,
      "versionNonce": 880311532,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783507692100,
      "link": null,
      "locked": false,
      "text": "USERS (ผู้ใช้งาน): เก็บข้อมูลทั้งผู้ซื้อ ผู้ขาย และผู้ดูแลระบบ รวมถึงสถานะระดับสมาชิก (Tier)\nและแต้มสะสมปัจจุบัน (Points) เพื่อรองรับระบบ Gamified Loyalty",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "USERS (ผู้ใช้งาน): เก็บข้อมูลทั้งผู้ซื้อ ผู้ขาย และผู้ดูแลระบบ รวมถึงสถานะระดับสมาชิก (Tier) และแต้มสะสมปัจจุบัน (Points) เพื่อรองรับระบบ Gamified Loyalty",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Ai0CzDWhou3cuWFmMKySo",
      "type": "text",
      "x": 48.473483215343094,
      "y": 334.2488654020001,
      "width": 727.71484375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#99e9f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
