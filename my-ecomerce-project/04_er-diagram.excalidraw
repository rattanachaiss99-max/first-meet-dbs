      "seed": 1272318421,
      "version": 189,
      "versionNonce": 687176309,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783498499318,
      "link": null,
      "locked": false,
      "text": "STORES (ร้านค้า): เชื่อมโยงกับ Users ที่เป็นผู้ขาย (Merchant) 1 ผู้ใช้สามารถมีได้ 1 ร้านค้า",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "STORES (ร้านค้า): เชื่อมโยงกับ Users ที่เป็นผู้ขาย (Merchant) 1 ผู้ใช้สามารถมีได้ 1 ร้านค้า",
      "autoResize": true,
      "lineHeight": 1.25
    },
