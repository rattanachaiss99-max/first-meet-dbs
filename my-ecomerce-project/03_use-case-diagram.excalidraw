      "updated": 1783506322416,
      "link": null,
      "locked": false,
      "text": "⚙️ 3. ฝั่งระบบ (Loyalty Engine)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "⚙️ 3. ฝั่งระบบ (Loyalty Engine)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "w4JeHcFGH_Kh1cb3DII2Z",
      "type": "text",
      "x": 1101.0130088409007,
      "y": 428.6822818338959,
      "width": 864.9038770635091,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "vxz5T8lO8MpbP2XhkXd1u"
      ],
      "frameId": null,
      "index": "a9",
      "roundness": null,
      "seed": 1135812386,
      "version": 403,
      "versionNonce": 1335032290,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783506322416,
      "link": null,
      "locked": false,
      "text": "อัปเกรดระดับ Tier (UC7) & แจกคูปอง (UC8): เมื่อระบบคำนวณยอดซื้อสะสม (Lifetime Points)\nถึงเกณฑ์ ระบบจะทำการอัปเกรด Tier ให้ลูกค้า (เช่นจาก Silver ไป Gold) และทริกเกอร์ UC8\nเพื่อส่งคูปองส่วนลดพิเศษเข้าไอดีเป็นของขวัญต้อนรับระดับใหม่ทันที สร้างความเซอร์ไพรส์และประทับใจ\n(Gamification)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "อัปเกรดระดับ Tier (UC7) & แจกคูปอง (UC8): เมื่อระบบคำนวณยอดซื้อสะสม (Lifetime Points) ถึงเกณฑ์ ระบบจะทำการอัปเกรด Tier ให้ลูกค้า (เช่นจาก Silver ไป Gold) และทริกเกอร์ UC8 เพื่อส่งคูปองส่วนลดพิเศษเข้าไอดีเป็นของขวัญต้อนรับระดับใหม่ทันที สร้างความเซอร์ไพรส์และประทับใจ (Gamification)",
      "autoResize": false,
      "lineHeight": 1.25
    },
