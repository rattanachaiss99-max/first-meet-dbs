    {
      "id": "w4JeHcFGH_Kh1cb3DII2Z",
      "type": "text",
      "x": 1281.0130088409007,
      "y": 430.3489485005625,
      "width": 864.9038770635091,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
